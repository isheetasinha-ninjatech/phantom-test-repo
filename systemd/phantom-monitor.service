[Unit]
Description=Phantom Teams Monitor
Documentation=https://github.com/NinjaTech-AI/phantom
After=network.target supervisor.service
Wants=supervisor.service

[Service]
Type=simple
User=phantom
WorkingDirectory=/workspace
ExecStartPre=/bin/sleep 10
ExecStart=/usr/local/bin/python -m phantom.teams_monitor --interval 30
Restart=always
RestartSec=30s

Environment=HOME=/home/phantom
Environment=DISPLAY=:99
Environment=PYTHONPATH=/workspace
StandardOutput=append:/workspace/logs/phantom-teams-monitor.log
StandardError=append:/workspace/logs/phantom-teams-monitor.log
SyslogIdentifier=phantom-teams-monitor

[Install]
WantedBy=multi-user.target
